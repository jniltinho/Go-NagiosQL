# Copie para .env e ajuste os valores antes de subir os containers.
# cp .env.example .env

# ── MariaDB ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword_mude_aqui
MYSQL_DATABASE=nagiosql
MYSQL_USER=nagiosql
MYSQL_PASSWORD=nagiosqlpass_mude_aqui
DB_PORT=3306

# ── Nagios Core ──────────────────────────────────────────────────────────────
# Senha do usuário nagiosadmin na interface web do Nagios Core
NAGIOS_ADMIN_PASSWORD=nagiosadmin_mude_aqui

# ── nagiosql REST API ─────────────────────────────────────────────────────────
# Usuário e senha do admin inicial
NAGIOSQL_USER=admin
NAGIOSQL_PASSWORD=admin_mude_aqui
# JWT secret: mínimo 32 caracteres aleatórios
# Gere com: openssl rand -hex 32
JWT_SECRET=change-me-to-at-least-32-random-characters

# ── Portas publicadas no host ─────────────────────────────────────────────────
# Interface web do Nagios Core → http://localhost:8080
NAGIOS_PORT=8080
# nagiosql REST API            → http://localhost:8081
NAGIOSQL_PORT=8081
